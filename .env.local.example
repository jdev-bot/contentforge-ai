# ContentForge AI - Frontend Environment Variables
# Copy this file to src/frontend/.env.local and fill in your actual values
# DO NOT commit .env.local to version control

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# =============================================================================
# SUPABASE - Authentication and Database
# Required: Get from https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# =============================================================================
# OPTIONAL: Payment (Stripe)
# Get from https://dashboard.stripe.com/apikeys
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# =============================================================================
# OPTIONAL: AI (Groq) - Only needed for client-side AI operations
# Get from https://console.groq.com/keys
# =============================================================================
NEXT_PUBLIC_GROQ_API_KEY=your_groq_api_key
