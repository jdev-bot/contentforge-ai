# ContentForge AI - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# =============================================================================
# SUPABASE - Authentication and Database
# Required: Get from https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
# Your Supabase project URL (e.g., https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Your Supabase anonymous/public key (safe to expose in client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Your Supabase service role key (keep secret - server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# AI / LLM PROVIDER - Content generation
# Supports: google, groq, cerebras, openrouter, or custom
# Set AI_PROVIDER and AI_API_KEY (required). AI_BASE_URL and AI_MODEL auto-default per provider.
# =============================================================================
# Provider: google | groq | cerebras | openrouter | custom
AI_PROVIDER=google

# API key for the chosen provider
AI_API_KEY=your_ai_api_key

# Override base URL (auto-set for known providers, required for 'custom')
# AI_BASE_URL=

# Override model (auto-defaults: google=gemini-2.5-flash, groq=llama-3.3-70b-versatile)
# AI_MODEL=

# =============================================================================
# LEGACY: Groq API (still supported as fallback if AI_API_KEY is not set)
# =============================================================================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# RESEND - Email service for transactional emails
# Required: Get from https://resend.com/api-keys
# =============================================================================
# Your Resend API key for sending emails
RESEND_API_KEY=your_resend_api_key

# =============================================================================
# STRIPE - Payment processing
# Required: Get from https://dashboard.stripe.com/apikeys
# =============================================================================
# Your Stripe secret key (starts with sk_...)
STRIPE_SECRET_KEY=your_stripe_secret_key

# Your Stripe publishable key (starts with pk_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Stripe webhook secret for webhook endpoint verification
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# =============================================================================
# CLOUDFLARE R2 - Object storage for file uploads
# Required: Get from https://dash.cloudflare.com/ -> R2
# =============================================================================
# Your Cloudflare account ID
R2_ACCOUNT_ID=your_cloudflare_account_id

# Your R2 access key ID
R2_ACCESS_KEY_ID=your_r2_access_key_id

# Your R2 secret access key
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Your R2 bucket name
R2_BUCKET_NAME=your_r2_bucket_name

# Your R2 public bucket URL (for serving files)
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket.r2.dev

# =============================================================================
# OPTIONAL: Application Configuration
# =============================================================================
# Next.js application URL (for callbacks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# =============================================================================
# DEPLOYMENT ENVIRONMENT — Controls staging vs production behavior
# Set to 'staging' for private testing, 'production' for public launch
# Effects when set to 'staging':
#   - All pages require authentication (no public access)
#   - robots.txt blocks all search engine indexing
#   - X-Robots-Tag: noindex header added to all responses
#   - Staging banner displayed at top of every page
#   - Signup shows "Invite Only" notice
# Effects when set to 'production' (or unset):
#   - Landing page, pricing, login are publicly accessible
#   - robots.txt allows indexing
#   - No staging banner
#   - Signup enabled normally
# =============================================================================
NEXT_PUBLIC_APP_ENV=production

# Enable/disable self-registration independently of APP_ENV
# Set to 'false' to disable signup form (admin invite-only)
NEXT_PUBLIC_SIGNUP_ENABLED=true

# =============================================================================
# BACKEND - Python/FastAPI Environment Variables
# Copy these to src/backend/.env for backend development
# =============================================================================

# Application settings
APP_NAME=ContentForge AI
APP_ENV=development
DEBUG=false

# Secret key for JWT signing (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your_secret_key_here

# Supabase (backend uses same credentials)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Redis URL for Celery task queue
REDIS_URL=redis://localhost:6379/0

# AI / LLM Provider
AI_PROVIDER=google
AI_API_KEY=your_ai_api_key
# AI_BASE_URL=  # auto-set per provider
# AI_MODEL=     # auto-defaults per provider

# Legacy Groq (fallback if AI_API_KEY not set)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# SMTP Email (optional, Resend preferred)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Stripe (backend)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# SSO/OIDC Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# SAML SSO (optional)
SAML_IDP_METADATA_URL=
SAML_IDP_ENTITY_ID=
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000"]

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
